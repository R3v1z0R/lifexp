# Base URL of the LifeXP API (defaults to http://localhost:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000
# Google Maps Android key — injected into the build by app.config.js (NOT committed to app.json).
# Set it locally here or as an EAS secret for builds. Without it, maps don't render on device.
GOOGLE_MAPS_ANDROID_API_KEY=
