{
  "name": "@lifexp/api",
  "version": "1.0.0",
  "description": "LifeXP API server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx ./src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx ./src/db/seed.ts",
    "db:migrate": "tsx ./src/db/migrate.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@lifexp/types": "workspace:*",
    "@lifexp/xp-engine": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.15.1",
    "drizzle-orm": "^0.45.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.1",
    "postgres": "^3.4.4",
    "stripe": "^17.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.7.0",
    "tsx": "^4.16.2",
    "typescript": "^5.6.0"
  }
}
